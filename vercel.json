{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/(manifest\\.json)", "dest": "/public/$1" },
    { "src": "/(sw\\.js)", "dest": "/public/$1" },
    { "src": "/(styles\\.css)", "dest": "/public/$1" },
    { "src": "/(app\\.js)", "dest": "/public/$1" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/index\\.html", "dest": "/public/index.html" },
    { "handle": "filesystem" }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
