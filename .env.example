# 食术养生 Vercel 环境变量配置
# 复制此文件为 .env 并填入实际值

# ===== 必需配置 =====

# JWT 密钥（用于生成用户 Token）
WELLNESS_SECRET=your-super-secret-key-here

# Turso 数据库配置（推荐）
# 在 https://turso.tech 注册获取
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ===== 可选配置 =====

# AI 服务（可选，不配置则使用规则引擎）
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# AI_PROVIDER=deepseek

# 微信支付配置（可选，不配置则使用模拟支付）
# WX_APPID=
# WX_SECRET=
# WX_MCHID=
# WX_V3_KEY=
# WX_SERIAL_NO=
# WX_PRIVATE_KEY=

# ===== Vercel 自动提供的环境变量 =====
# VERCEL=1
# VERCEL_ENV=production
# NODE_ENV=production
